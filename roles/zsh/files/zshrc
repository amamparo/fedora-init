# fedora-init — installed to ~/.zshrc
export PATH="$HOME/.local/bin:$PATH"  # user-installed CLIs (claude, etc.); zsh doesn't get this from /etc/profile
export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"
plugins=(git)

source "$ZSH/oh-my-zsh.sh"

# mise: runtime versions (node/python/java) — hooks cd to apply per-project
# pins. Guarded so the shell works before the mise role has run.
command -v mise >/dev/null && eval "$(mise activate zsh)"
