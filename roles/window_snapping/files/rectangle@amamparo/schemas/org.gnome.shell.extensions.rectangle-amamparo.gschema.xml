<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.rectangle-amamparo"
          path="/org/gnome/shell/extensions/rectangle-amamparo/">
    <key name="tile-left" type="as">
      <default>['&lt;Super&gt;&lt;Alt&gt;Left']</default>
      <summary>Tile window left, cycling 1/2, 2/3, 1/3 widths</summary>
    </key>
    <key name="tile-right" type="as">
      <default>['&lt;Super&gt;&lt;Alt&gt;Right']</default>
      <summary>Tile window right, cycling 1/2, 2/3, 1/3 widths</summary>
    </key>
    <key name="tile-up" type="as">
      <default>['&lt;Super&gt;&lt;Alt&gt;Up']</default>
      <summary>Tile window to the top, cycling 1/2, 2/3, 1/3 heights</summary>
    </key>
    <key name="tile-down" type="as">
      <default>['&lt;Super&gt;&lt;Alt&gt;Down']</default>
      <summary>Tile window to the bottom, cycling 1/2, 2/3, 1/3 heights</summary>
    </key>
  </schema>
</schemalist>
